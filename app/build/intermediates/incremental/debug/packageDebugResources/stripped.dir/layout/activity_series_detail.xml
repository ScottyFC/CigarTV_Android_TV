<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/charcoal">

    <!-- Pinned header band -->
    <View
        android:id="@+id/header_band"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@color/ink"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/header_hairline"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/ember"
        android:alpha="0.4"
        app:layout_constraintTop_toBottomOf="@id/header_band"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/detail_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/poppins_extrabold"
        android:textColor="@color/paper"
        android:textSize="34sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/detail_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="80dp"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:textColor="@color/smoke_100"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/detail_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Season selector -->
    <Spinner
        android:id="@+id/season_spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="240dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="16dp"
        android:popupBackground="@color/ink"
        app:layout_constraintTop_toBottomOf="@id/header_hairline"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Episode list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/episode_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:clipToPadding="false"
        android:paddingBottom="48dp"
        app:layout_constraintTop_toBottomOf="@id/season_spinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
